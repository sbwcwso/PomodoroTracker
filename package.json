{
  "name": "pomodoro-tracker",
  "version": "0.1.0",
  "description": "支持分级事项的本地番茄钟记录工具",
  "main": "src/main/main.js",
  "type": "commonjs",
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "start": "electron .",
    "check": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "pretest": "npm rebuild better-sqlite3",
    "test": "node --test",
    "posttest": "electron-rebuild -f -w better-sqlite3",
    "dist:dir": "electron-builder --dir",
    "dist:win": "electron-builder --win nsis --x64",
    "dist:linux": "electron-builder --linux AppImage --x64"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "electron": "^37.10.3",
    "electron-builder": "^26.0.12",
    "eslint": "^9.31.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-jsdoc": "^50.8.0",
    "prettier": "^3.6.2"
  },
  "build": {
    "appId": "dev.pomodoro.tracker",
    "productName": "番茄钟",
    "artifactName": "pomodoro-tracker-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "番茄钟"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility",
      "executableName": "pomodoro-tracker",
      "synopsis": "支持分级事项和本地记录的番茄钟"
    }
  }
}
